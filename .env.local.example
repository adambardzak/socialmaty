# --- Training video (Page #2) ---
# Fallback chain: BUNNY → YT_ID → VIDEO_URL → self-hosted /trenink_zdarma_720p.mp4
NEXT_PUBLIC_TRAINING_BUNNY=
NEXT_PUBLIC_TRAINING_YT_ID=
NEXT_PUBLIC_TRAINING_VIDEO_URL=

# --- Ecomail ---
# https://app.ecomail.cz/integrations/api
ECOMAIL_API_KEY=
ECOMAIL_LIST_ID=

# --- Circle.so admin v2 ---
