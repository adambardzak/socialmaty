# =====================================================
# Socialmaty / Projekt Organika — env vars
# Copy to .env.local and fill in.
# =====================================================

NEXT_PUBLIC_BASE_URL=https://socialmaty.cz
NEXT_PUBLIC_CIRCLE_URL=https://growmat.circle.so

# --- Training video (Page #2) ---
# Use either a YouTube ID OR a direct video URL (e.g. Bunny.net signed URL)
NEXT_PUBLIC_TRAINING_YT_ID=
NEXT_PUBLIC_TRAINING_VIDEO_URL=

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Ecomail ---
# https://app.ecomail.cz/integrations/api
ECOMAIL_API_KEY=
ECOMAIL_LIST_ID=

# --- Circle.so ---
# https://help.circle.so/c/developers/headless-auth-api
CIRCLE_API_TOKEN=
CIRCLE_COMMUNITY_ID=
CIRCLE_SPACE_ID=

# --- Vercel KV (counter, optional in dev) ---
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
